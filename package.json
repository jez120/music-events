{
  "name": "music-events",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.15.8",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "fmt": "prettier --write .",
    "prepare": "husky install"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md,yml,yaml}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
